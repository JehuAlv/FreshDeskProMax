# ── FreshDesk ──
FRESHDESK_DOMAIN=kyexpert
FRESHDESK_API_KEY=your_freshdesk_api_key

# ── Microsoft Graph (Azure AD App) ──
# Register an app at https://portal.azure.com → Azure Active Directory → App registrations
# 1. Create a new registration (any name, e.g. "FreshDesk SharePoint Tool")
# 2. Set "Supported account types" to "Accounts in this organizational directory only"
# 3. Under "Authentication" → "Add a platform" → "Mobile and desktop applications"
#    Check the redirect URI: https://login.microsoftonline.com/common/oauth2/nativeclient
# 4. Under "API permissions" → "Add a permission" → "Microsoft Graph" → "Delegated permissions"
#    Add: Files.ReadWrite, User.Read
# 5. Click "Grant admin consent" (or ask your admin)
AZURE_CLIENT_ID=your_azure_app_client_id
AZURE_TENANT_ID=your_azure_tenant_id

# ── OneDrive target folder ──
# Sharing URL of the OneDrive/SharePoint folder where ticket folders are created
# Get this by right-clicking the folder in OneDrive > "Copy link"
ONEDRIVE_FOLDER_URL=https://kohyoung-my.sharepoint.com/:f:/p/your_user/your_folder_id

# ── Sharing options ──
# Role to grant: "read" or "write" (default: write)
SHARE_ROLE=write
# Send email notification to shared users: true/false (default: false)
SEND_INVITATION=false

# ── Email filtering ──
# Comma-separated emails to exclude from sharing (e.g., support inboxes)
EXCLUDE_EMAILS=kya_support@kohyoung.com,kohyoungcomkya_support@kyexpert.freshdesk.com
# Comma-separated domains to exclude entirely (optional)
EXCLUDE_DOMAINS=
